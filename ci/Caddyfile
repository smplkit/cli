# Reverse proxy for the CLI acceptance-test platform.
# Routes *.localhost subdomains to the matching docker-compose service.
# Mirrors terraform-provider-smplkit/ci/Caddyfile.

http://app.localhost {
	reverse_proxy app:8000
}

http://config.localhost {
	reverse_proxy config:8000
}

http://flags.localhost {
	reverse_proxy flags:8000
}

http://logging.localhost {
	reverse_proxy logging:8000
}

http://audit.localhost {
	reverse_proxy audit:8000
}
